---
import '../styles/global.css';
import favicon16 from '../assets/shuo_favicon_32x32.png';
import favicon32 from '../assets/shuo_128x128.png';
import appleTouchIcon from '../assets/shuo_128x128.png';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
}

const {
  title = "Shuo - Professional Local Voice Input Method",
  description = "Shuo, a professional, local-first voice input method. No vendor lock-in, core capabilities run locally. Privacy-friendly. Supports macOS and Windows.",
  keywords = "Shuo,voice input,local voice,AI input method,professional input method,macOS,Windows",
  canonical = "https://shuo.us/"
} = Astro.props;
---

<!DOCTYPE html>
<html :class="{ 'dark': $store.theme.isDark }" :lang="$store.i18n.lang === 'zh' ? 'zh-CN' : 'en'" x-data>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link href={appleTouchIcon.src} rel="apple-touch-icon" sizes="256x256" />
    <link href={favicon32.src} rel="icon" sizes="32x32" type="image/png" />
    <link href={favicon16.src} rel="icon" sizes="16x16" type="image/png" />
    <link href="/shuo_favicon_32x32.ico" rel="icon" />
    <link href="/shuo_desktop_icon.ico" rel="icon" sizes="256x256" type="image/x-icon" />
    <link href="/site.webmanifest" rel="manifest" />
    <meta name="generator" content={Astro.generator} />
    
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link href={canonical} rel="canonical" />
    
    <title>{title}</title>
    
    <meta content="website" property="og:type" />
    <meta content={canonical} property="og:url" />
    <meta content={title} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content="/logo.png" property="og:image" />
    <meta content="Shuo" property="og:site_name" />
    <meta content="en_US" property="og:locale" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={title} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content="/logo.png" name="twitter:image" />

    <!-- Google Fonts for Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Theme Script to Prevent Flash -->
    <script is:inline>
      document.documentElement.classList.remove('dark');
    </script>
  </head>
  <body class="flex flex-col antialiased bg-primary-50 dark:bg-primary-950 dark:text-primary-200 min-h-screen pt-16 sm:pt-20 text-primary-950 transition duration-150">
    
    <!-- Header / Navbar -->
    <header :class="{ 'bg-primary-500/10 dark:bg-primary-400/10': open, 'bg-primary-50/80 dark:bg-primary-950/80': !(open) }" class="fixed backdrop-blur-sm left-0 right-0 top-0 transition z-50" x-data="{ open: false }">
      <div class="items-center flex justify-between lg:max-w-7xl lg:px-8 max-w-2xl mx-auto px-4 py-4 sm:px-6">
        <div class="flex">
          <a class="items-center flex gap-3 dark:group-focus-visible:outline-primary-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-primary-950 rounded-md" href="/">
            <span class="sr-only" x-text="$store.i18n.t('header.brand')">Shuo</span>
            <img alt="Shuo" class="w-auto h-8 rounded-lg" src="/logo.png" />
            <span class="dark:text-primary-200 text-primary-950 font-semibold text-xl" x-text="$store.i18n.t('header.brand')">Shuo</span>
          </a>
        </div>
        
        <div class="items-center flex -mr-2 sm:space-x-5 space-x-2">
          <a class="text-base font-medium dark:text-primary-200 dark:hover:text-primary-400 text-primary-950 hover:text-primary-600 transition-colors hidden sm:inline-flex" href="/" x-text="$store.i18n.t('mobileMenu.home')">Home</a>
          <a class="text-base font-medium dark:text-primary-200 dark:hover:text-primary-400 text-primary-950 hover:text-primary-600 transition-colors hidden sm:inline-flex" href="/about" x-text="$store.i18n.t('mobileMenu.about')">About</a>
          <a class="text-base font-medium dark:text-primary-200 dark:hover:text-primary-400 text-primary-950 hover:text-primary-600 transition-colors hidden sm:inline-flex" href="/pricing" x-text="$store.i18n.t('mobileMenu.pricing')">Pricing</a>
          <a class="text-base font-medium dark:text-primary-200 dark:hover:text-primary-400 text-primary-950 hover:text-primary-600 transition-colors hidden sm:inline-flex" href="/contact" x-text="$store.i18n.t('mobileMenu.contact')">Contact</a>
          <!-- Download button -->
          <button type="button" class="items-center justify-center rounded-full font-semibold gap-2 transition bg-primary-900 dark:bg-primary-100 dark:focus-visible:ring-white dark:hover:bg-white dark:text-primary-950 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary-900 focus:outline-none hidden hover:bg-primary-800 px-5 py-2.5 shadow-sm sm:inline-flex text-sm text-white cursor-default opacity-80" id="header-download-btn">
            <span id="header-download-text" x-text="$store.i18n.t('header.download')">Coming Soon</span>
          </button>
          
          <!-- Language Toggle -->
          <button class="items-center justify-center rounded-full inline-flex transition dark:hover:bg-primary-400/10 dark:text-primary-200 focus-visible:ring-2 focus:outline-none h-14 hover:bg-primary-500/10 ring-primary-950 text-primary-950 w-14 gap-1" type="button" @click="$store.i18n.toggle()" aria-label="Toggle language">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="text-xs font-semibold" x-text="$store.i18n.lang === 'en' ? 'EN' : '中'">EN</span>
          </button>
          
          <!-- Mobile Menu Toggle Button -->
          <button
            type="button"
            class="text-primary-950 dark:text-primary-200 hover:bg-primary-500/10 dark:hover:bg-primary-400/10 ring-primary-950 sm:hidden inline-flex h-14 w-14 items-center justify-center rounded-full transition focus:outline-none focus-visible:ring-2"
            @click="open = !open"
            @mousedown="if (open) $event.preventDefault()"
            aria-controls="website-menu"
            aria-expanded="false"
            :aria-expanded="open.toString()"
          >
            <span class="sr-only">Toggle menu</span>
            <svg x-cloak class="h-8 w-8" :class="{ 'hidden': open, 'block': !(open) }" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 8H5V10H19V8ZM19 14H5V16H19V14Z"></path>
            </svg>
            <svg x-cloak class="h-8 w-8" :class="{ 'block': open, 'hidden': !(open) }" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.0007 10.5865L16.9504 5.63672L18.3646 7.05093L13.4149 12.0007L18.3646 16.9504L16.9504 18.3646L12.0007 13.4149L7.05093 18.3646L5.63672 16.9504L10.5865 12.0007L5.63672 7.05093L7.05093 5.63672L12.0007 10.5865Z"></path>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Collapsible Mobile Menu -->
      <div class="max-w-2xl lg:max-w-7xl lg:px-8 mx-auto px-4 sm:px-6" id="website-menu" x-cloak x-collapse x-collapse.duration.500ms x-show="open">
        <div class="grid lg:grid-cols-2 gap-16 grid-cols-1 lg:pt-12 pb-24 pt-6">
          <div class="items-center justify-center dark:bg-primary-400/10 bg-primary-500/10 hidden lg:flex px-6 py-8 rounded-3xl">
            <p class="text-xl dark:text-primary-200/70 text-primary-950/70 italic leading-loose max-w-sm">
              <span class="font-medium" x-text="$store.i18n.t('header.brand')">Shuo</span>
              <span x-show="$store.i18n.lang === 'en'" x-cloak> Turn voice into text. Professional, local-first, privacy in your hands.</span>
              <span x-show="$store.i18n.lang === 'zh'" x-cloak> 把语音变成文字，专业、本地优先，隐私由你掌控。</span>
            </p>
          </div>
          <nav class="flex flex-col dark:divide-primary-300/10 divide-primary-900/10 divide-y gap-1">
            <a class="font-medium dark:text-primary-200 text-primary-950 text-3xl tracking-tight sm:text-4xl focus-visible:outline-none group inline-flex py-6 sm:py-8 transition" href="/">
              <div class="items-center flex dark:group-focus-visible:outline-primary-200 flex-1 group-focus-visible:outline group-focus-visible:outline-2 group-focus-visible:outline-offset-2 group-focus-visible:outline-primary-950 justify-between rounded-3xl">
                <div class="items-center flex gap-6">
                  <span class="text-xs">01</span>
                  <span class="group-hover:underline" x-text="$store.i18n.t('mobileMenu.home')">Home</span>
                </div>
                <svg class="dark:text-primary-400 text-primary-600 h-6 w-6 sm:h-8 sm:w-8" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
                </svg>
              </div>
            </a>
            <a class="font-medium dark:text-primary-200 text-primary-950 text-3xl tracking-tight sm:text-4xl focus-visible:outline-none group inline-flex py-6 sm:py-8 transition" href="/about">
              <div class="items-center flex dark:group-focus-visible:outline-primary-200 flex-1 group-focus-visible:outline group-focus-visible:outline-2 group-focus-visible:outline-offset-2 group-focus-visible:outline-primary-950 justify-between rounded-3xl">
                <div class="items-center flex gap-6">
                  <span class="text-xs">02</span>
                  <span class="group-hover:underline" x-text="$store.i18n.t('mobileMenu.about')">About</span>
                </div>
                <svg class="dark:text-primary-400 text-primary-600 h-6 w-6 sm:h-8 sm:w-8" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
                </svg>
              </div>
            </a>
            <a class="font-medium dark:text-primary-200 text-primary-950 text-3xl tracking-tight sm:text-4xl focus-visible:outline-none group inline-flex py-6 sm:py-8 transition" href="/pricing">
              <div class="items-center flex dark:group-focus-visible:outline-primary-200 flex-1 group-focus-visible:outline group-focus-visible:outline-2 group-focus-visible:outline-offset-2 group-focus-visible:outline-primary-950 justify-between rounded-3xl">
                <div class="items-center flex gap-6">
                  <span class="text-xs">03</span>
                  <span class="group-hover:underline" x-text="$store.i18n.t('mobileMenu.pricing')">Pricing</span>
                </div>
                <svg class="dark:text-primary-400 text-primary-600 h-6 w-6 sm:h-8 sm:w-8" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
                </svg>
              </div>
            </a>
            <a class="font-medium dark:text-primary-200 text-primary-950 text-3xl tracking-tight sm:text-4xl focus-visible:outline-none group inline-flex py-6 sm:py-8 transition" href="/contact">
              <div class="items-center flex dark:group-focus-visible:outline-primary-200 flex-1 group-focus-visible:outline group-focus-visible:outline-2 group-focus-visible:outline-offset-2 group-focus-visible:outline-primary-950 justify-between rounded-3xl">
                <div class="items-center flex gap-6">
                  <span class="text-xs">04</span>
                  <span class="group-hover:underline" x-text="$store.i18n.t('mobileMenu.contact')">Contact</span>
                </div>
                <svg class="dark:text-primary-400 text-primary-600 h-6 w-6 sm:h-8 sm:w-8" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"></path>
                </svg>
              </div>
            </a>
          </nav>
        </div>
      </div>
    </header>
    
    <script is:inline>
      function initNavbarBtn() {
        const btn = document.getElementById("header-download-btn");
        if (!btn) return;
        btn.style.display = "inline-flex";
      }
      document.addEventListener("DOMContentLoaded", initNavbarBtn);
      document.addEventListener("astro:page-load", initNavbarBtn);
    </script>
    
    <!-- Main Slot Content -->
    <main class="flex-1">
      <slot />
    </main>
    
    <!-- Footer -->
    <footer aria-labelledby="footer-heading" class="py-16 bg-primary-500/10 dark:bg-primary-400/10 lg:mt-20 lg:py-20 mt-16" id="footer">
      <h2 class="sr-only" id="footer-heading">Footer</h2>
      <div class="max-w-2xl lg:max-w-7xl lg:px-8 mx-auto px-4 sm:px-6">
        <div class="flex flex-col gap-12 lg:flex-row lg:gap-16 justify-between">
          <div class="flex flex-col gap-12 lg:flex-row lg:gap-16 flex-1 md:flex-row">
            <div class="flex flex-col gap-6 lg:min-w-[280px]">
              <div class="items-center flex gap-3">
                <img alt="Shuo" class="h-10 rounded-lg w-10" src="/logo.png" />
                <span class="dark:text-primary-200 text-primary-950 text-xl font-bold" x-text="$store.i18n.t('footer.brand')">Shuo</span>
              </div>
              <p class="text-sm dark:text-primary-200/70 text-primary-950/70 leading-relaxed max-w-xs" x-text="$store.i18n.t('footer.desc')">Open source, local-first voice input method.</p>
            </div>
            
            <div class="grid gap-8 grid-cols-1 lg:gap-12 lg:grid-cols-3 sm:grid-cols-2">
              <div class="flex flex-col gap-4">
                <h3 class="text-sm dark:text-primary-200 text-primary-950 font-semibold tracking-wider uppercase" x-text="$store.i18n.t('footer.social')">Social Media</h3>
                <ul class="flex flex-col gap-2.5" role="list">
                  <li>
                    <button class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors cursor-pointer" type="button" aria-controls="wechat-service-qr-modal" aria-haspopup="dialog" data-modal-target="wechat-service-qr-modal">
                      <span class="group-hover:underline" x-text="$store.i18n.t('footer.wechat')">WeChat</span>
                    </button>
                  </li>
                  <li>
                     <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://shuo.us" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">抖音</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                     <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://shuo.us" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">小红书</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                     <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://shuo.us" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">哔哩哔哩</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                     <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://shuo.us" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">X</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://github.com/shuo-us/shuo-website" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">Github</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                </ul>
              </div>
              
              <div class="flex flex-col gap-4">
                <h3 class="text-sm dark:text-primary-200 text-primary-950 font-semibold tracking-wider uppercase" x-text="$store.i18n.t('footer.resources')">Resources</h3>
                <ul class="flex flex-col gap-2.5" role="list">
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://github.com/shuo-us/shuo-website/issues" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline" x-text="$store.i18n.t('footer.feedback')">Feedback</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://github.com/shuo-us/shuo-website/projects" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline" x-text="$store.i18n.t('footer.roadmap')">Roadmap</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
