                <ul class="flex flex-col gap-2.5" role="list">
                  <li>
                    <button class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors cursor-pointer" type="button" aria-controls="wechat-service-qr-modal" aria-haspopup="dialog" data-modal-target="wechat-service-qr-modal">
                      <span class="group-hover:underline" x-text="$store.i18n.t('footer.wechat')">WeChat</span>
                    </button>
                  </li>
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://v.douyin.com/meT5rx3eY4w/" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">抖音</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://www.xiaohongshu.com/user/profile/67508770000000001c018a21" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">小红书</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 6V8H5V19H16V14H18V20C18 20.5523 17.5523 21 17 21H4C3.44772 21 3 20.5523 3 20V7C3 6.44772 3.44772 6 4 6H10ZM21 3V11H19L18.9999 6.413L11.2071 14.2071L9.79289 12.7929L17.5849 5H13V3H21Z"></path>
                      </svg>
                    </a>
                  </li>
                  <li>
                    <a class="items-center inline-flex focus-visible:outline focus-visible:outline-2 dark:focus-visible:outline-primary-200 dark:hover:text-primary-200 dark:text-primary-200/70 duration-200 focus-visible:outline-primary-950 gap-1.5 group hover:text-primary-950 rounded-md text-primary-950/70 text-sm transition-colors" href="https://b23.tv/AAkNqGf" rel="noopener noreferrer" target="_blank">
                      <span class="group-hover:underline">哔哩哔哩</span>
                      <svg class="h-3.5 w-3.5 group-hover:opacity-100 opacity-50 transition-opacity" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
