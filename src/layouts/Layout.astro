    <!-- Modal Logic Script -->
    <script is:inline>
      function initModals() {
        const targets = document.querySelectorAll("[data-modal-target]");
        const closes = document.querySelectorAll("[data-modal-close]");
        
        const closeModal = (id) => {
          const el = document.getElementById(id);
          if (el) {
            el.classList.add("hidden");
            el.classList.remove("flex");
            document.body.style.overflow = "";
            document.body.style.paddingRight = "";
          }
        };
        
        const openModal = (id) => {
          const el = document.getElementById(id);
          if (!el) return;
          const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
          el.classList.remove("hidden");
          el.classList.add("flex");
          document.body.style.overflow = "hidden";
          if (scrollBarWidth > 0) {
            document.body.style.paddingRight = `${scrollBarWidth}px`;
          }
        };

        targets.forEach(el => {
          if (el.dataset.modalBound !== "true") {
            el.dataset.modalBound = "true";
            el.addEventListener("click", () => {
              const target = el.getAttribute("data-modal-target");
              if (target) openModal(target);
            });
          }
        });

        closes.forEach(el => {
          if (el.dataset.modalBound !== "true") {
            el.dataset.modalBound = "true";
            el.addEventListener("click", () => {
              const target = el.getAttribute("data-modal-close");
              if (target) closeModal(target);
            });
          }
        });

        document.querySelectorAll('[role="dialog"][aria-modal="true"]').forEach(el => {
          if (el.dataset.modalOverlayBound !== "true") {
            el.dataset.modalOverlayBound = "true";
            el.addEventListener("click", (e) => {
              if (e.target === el && el.id) closeModal(el.id);
            });
          }
        });

        if (document.body.dataset.footerModalEscBound !== "true") {
          document.body.dataset.footerModalEscBound = "true";
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
              document.querySelectorAll('[role="dialog"][aria-modal="true"]').forEach(modal => {
                if (!modal.classList.contains("hidden") && modal.id) closeModal(modal.id);
              });
            }
          });
        }
      }
      document.addEventListener("DOMContentLoaded", initModals);
      document.addEventListener("astro:page-load", initModals);
    </script>
    
    <!-- Theme + i18n Alpine.js Client Bootloader -->
    <script>
      import Alpine from 'alpinejs';
      import collapse from '@alpinejs/collapse';
      import { translations } from '../i18n/translations';
      
      if (!window.Alpine) {
        Alpine.plugin(collapse);
        
        Alpine.store('theme', {
          isDark: false
        });
        
        Alpine.store('i18n', {
          lang: 'en',
          init() {
            this.lang = localStorage.getItem('lang') || 'en';
          },
          toggle() {
            this.lang = this.lang === 'en' ? 'zh' : 'en';
            localStorage.setItem('lang', this.lang);
          },
          t(key) {
            const keys = key.split('.');
            let result = translations[this.lang];
            for (const k of keys) {
              if (result && typeof result === 'object' && k in result) {
                result = result[k];
              } else {
                return key;
              }
            }
            return result;
          }
        });
        
        window.Alpine = Alpine;
        Alpine.start();
      }
    </script>
