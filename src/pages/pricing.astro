---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="py-16 sm:py-20">
    <div class="px-4 lg:max-w-7xl lg:px-8 max-w-2xl mx-auto sm:px-6">
      <!-- Header -->
      <div class="flex flex-col gap-4 text-center pb-16 sm:pb-20">
        <h1 class="font-medium tracking-tight sm:text-5xl text-4xl" x-text="$store.i18n.t('pricing.title')">
        </h1>
        <p class="text-base text-primary-950/60 dark:text-primary-200/60 max-w-2xl mx-auto" x-text="$store.i18n.t('pricing.subtitle')">
        </p>
      </div>
      
      <!-- Pricing Cards -->
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 max-w-4xl mx-auto">
        <!-- Free -->
        <div class="flex flex-col gap-8 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 p-8 rounded-3xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <h2 class="font-medium text-2xl tracking-tight" x-text="$store.i18n.t('pricing.freeTitle')"></h2>
              <span class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-green-500/10 border border-green-200/20 dark:text-green-400 text-green-700" x-text="$store.i18n.t('pricing.freeBadge')">
              </span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="font-medium text-5xl tracking-tight" x-text="$store.i18n.t('pricing.freePrice')"></span>
              <span class="text-primary-950/60 dark:text-primary-200/60 text-sm" x-text="$store.i18n.t('pricing.freePeriod')"></span>
            </div>
            <p class="text-sm text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.freeDesc')">
            </p>
          </div>
          
          <button type="button" class="w-full inline-flex items-center justify-center gap-2 rounded-full border px-6 py-3.5 text-base font-semibold transition border-primary-200 dark:border-primary-700 text-primary-950 dark:text-primary-200 hover:bg-primary-50 dark:hover:bg-primary-900/50 active:scale-95 hover:scale-105 cursor-default opacity-80" x-text="$store.i18n.t('pricing.freeBtn')">
          </button>
          
          <div class="flex flex-col gap-4">
            <p class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.freeFeatures')"></p>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF1')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF2')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF3')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF4')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF5')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.freeF6')"></span>
              </li>
            </ul>
          </div>
        </div>
        
        <!-- Pro -->
        <div class="flex flex-col gap-8 bg-white border-2 border-primary-600 dark:bg-primary-950 dark:border-primary-400 p-8 rounded-3xl relative shadow-xl">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium px-4 py-1.5 rounded-full bg-primary-600 dark:bg-primary-400 text-white dark:text-primary-950" x-text="$store.i18n.t('pricing.proPopular')">
            </span>
          </div>
          
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <h2 class="font-medium text-2xl tracking-tight" x-text="$store.i18n.t('pricing.proTitle')"></h2>
              <span class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-primary-600/10 border border-primary-200/20 dark:text-primary-400 text-primary-700" x-text="$store.i18n.t('pricing.proBadge')">
              </span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="font-medium text-5xl tracking-tight" x-text="$store.i18n.t('pricing.proPrice')"></span>
              <span class="text-primary-950/60 dark:text-primary-200/60 text-sm" x-text="$store.i18n.t('pricing.proPeriod')"></span>
            </div>
            <p class="text-sm text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.proDesc')">
            </p>
          </div>
          
          <button type="button" class="w-full inline-flex items-center justify-center gap-2 rounded-full border px-6 py-3.5 text-base font-semibold transition bg-primary-900 dark:bg-primary-100 hover:bg-primary-800 dark:hover:bg-white border-transparent text-white dark:text-primary-950 shadow-lg hover:shadow-xl active:scale-95 hover:scale-105 cursor-default opacity-80" x-text="$store.i18n.t('pricing.proBtn')">
          </button>
          
          <div class="flex flex-col gap-4">
            <p class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.proFeatures')"></p>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.proF1')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.proF2')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.proF3')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.proF4')"></span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.proF5')"></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- Feature Comparison Table -->
      <div class="mt-20 max-w-4xl mx-auto">
        <h2 class="font-medium text-2xl tracking-tight text-center mb-10" x-text="$store.i18n.t('pricing.tableTitle')"></h2>
        <div class="overflow-hidden border border-primary-900/10 dark:border-primary-200/10 rounded-2xl">
          <table class="w-full">
            <thead>
              <tr class="bg-primary-500/5 dark:bg-primary-400/5">
                <th class="text-left p-4 text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.tableFeature')"></th>
                <th class="text-center p-4 text-sm font-medium dark:text-primary-200 text-primary-950 w-32" x-text="$store.i18n.t('pricing.tableOpen')"></th>
                <th class="text-center p-4 text-sm font-medium dark:text-primary-200 text-primary-950 w-32" x-text="$store.i18n.t('pricing.tablePro')"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-primary-900/5 dark:divide-primary-200/5">
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableLocalAsr')"></td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableCloudAsr')"></td>
                <td class="p-4 text-center text-sm text-primary-950/40 dark:text-primary-200/40">—</td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableCustomAi')"></td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableAutoStruct')"></td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableColloquial')"></td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableAdvanced')"></td>
                <td class="p-4 text-center text-sm text-primary-950/40 dark:text-primary-200/40">—</td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableMemory')"></td>
                <td class="p-4 text-center text-sm text-primary-950/40 dark:text-primary-200/40">—</td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableLang')"></td>
                <td class="p-4 text-center text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableLangFree')"></td>
                <td class="p-4 text-center text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableLangPro')"></td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tablePriority')"></td>
                <td class="p-4 text-center text-sm text-primary-950/40 dark:text-primary-200/40">—</td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
              <tr>
                <td class="p-4 text-sm dark:text-primary-200/70 text-primary-950/70" x-text="$store.i18n.t('pricing.tableEarly')"></td>
                <td class="p-4 text-center text-sm text-primary-950/40 dark:text-primary-200/40">—</td>
                <td class="p-4 text-center">
                  <svg class="h-5 w-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      
      <!-- Security Features -->
      <div class="mt-20 max-w-4xl mx-auto">
        <h2 class="font-medium text-2xl tracking-tight text-center mb-10" x-text="$store.i18n.t('pricing.securityTitle')"></h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="flex flex-col items-center gap-3 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl">
            <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.sec1Title')"></span>
            <span class="text-xs text-center text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.sec1Desc')"></span>
          </div>
          <div class="flex flex-col items-center gap-3 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl">
            <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.sec2Title')"></span>
            <span class="text-xs text-center text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.sec2Desc')"></span>
          </div>
          <div class="flex flex-col items-center gap-3 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl">
            <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.sec3Title')"></span>
            <span class="text-xs text-center text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.sec3Desc')"></span>
          </div>
          <div class="flex flex-col items-center gap-3 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl">
            <svg class="h-8 w-8 text-green-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"></path>
            </svg>
            <span class="text-sm font-medium dark:text-primary-200 text-primary-950" x-text="$store.i18n.t('pricing.sec4Title')"></span>
            <span class="text-xs text-center text-primary-950/60 dark:text-primary-200/60" x-text="$store.i18n.t('pricing.sec4Desc')"></span>
          </div>
        </div>
