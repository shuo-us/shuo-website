---
import Layout from '../layouts/Layout.astro';
---

<Layout title="定价 · 说说输入法" description="说说输入法定价 - 开源免费，Pro 版提供更多高级功能。">
  <section class="py-16 sm:py-20">
    <div class="px-4 lg:max-w-7xl lg:px-8 max-w-2xl mx-auto sm:px-6">
      <!-- Header -->
      <div class="flex flex-col gap-4 text-center pb-16 sm:pb-20">
        <h1 class="font-medium tracking-tight sm:text-5xl text-4xl">
          选择适合你的方案
        </h1>
        <p class="text-base text-primary-950/60 dark:text-primary-200/60 max-w-2xl mx-auto">
          开源免费，Pro 版提供更多高级功能，助力高效语音输入
        </p>
      </div>
      
      <!-- Pricing Cards -->
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 max-w-4xl mx-auto">
        <!-- Free -->
        <div class="flex flex-col gap-8 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 p-8 rounded-3xl">
          <div class="flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <h2 class="font-medium text-2xl tracking-tight">开源版</h2>
              <span class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full bg-green-500/10 border border-green-200/20 dark:text-green-400 text-green-700">
                免费
              </span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="font-medium text-5xl tracking-tight">$0</span>
              <span class="text-primary-950/60 dark:text-primary-200/60 text-sm">永久免费</span>
            </div>
            <p class="text-sm text-primary-950/60 dark:text-primary-200/60">
              完整的本地语音输入体验，开源透明
            </p>
          </div>
          
          <a class="w-full inline-flex items-center justify-center gap-2 rounded-full border px-6 py-3.5 text-base font-semibold transition border-primary-200 dark:border-primary-700 text-primary-950 dark:text-primary-200 hover:bg-primary-50 dark:hover:bg-primary-900/50 active:scale-95 hover:scale-105" href="https://github.com/shuo-us/shuo/releases/latest">
            下载使用
          </a>
          
          <div class="flex flex-col gap-4">
            <p class="text-sm font-medium dark:text-primary-200 text-primary-950">包含功能：</p>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70">本地语音识别</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                <span class="dark:text-primary-200/70 text-primary-950/70">自定义 AI 服务商</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
