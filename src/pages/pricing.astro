                <th class="text-center p-4 text-sm font-medium dark:text-primary-200 text-primary-950 w-32">开源版</th>
                <th class="text-center p-4 text-sm font-medium dark:text-primary-200 text-primary-950 w-32">Pro 版</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-primary-900/5 dark:divide-primary-200/5">
