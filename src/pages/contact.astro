---
import Layout from '../layouts/Layout.astro';
---

<Layout title="联系 · 说说输入法" description="联系说说输入法团队 - 通过 GitHub Issues、邮件或微信与我们取得联系。">
  <section class="py-16 sm:py-20">
    <div class="px-4 lg:max-w-7xl lg:px-8 max-w-2xl mx-auto sm:px-6">
      <!-- Header -->
      <div class="flex flex-col gap-4 text-center pb-16 sm:pb-20">
        <h1 class="font-medium tracking-tight sm:text-5xl text-4xl">
          联系我们
        </h1>
        <p class="text-base text-primary-950/60 dark:text-primary-200/60 max-w-2xl mx-auto">
          有问题或建议？欢迎通过以下方式联系我们
        </p>
      </div>
      
      <!-- Contact Methods -->
      <div class="max-w-3xl mx-auto">
        <div class="grid gap-6 sm:grid-cols-2">
          <!-- GitHub Issues -->
          <a class="flex flex-col gap-4 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl hover:border-primary-600/30 dark:hover:border-primary-400/30 transition-colors group" href="https://github.com/shuo-us/shuo/issues" rel="noopener noreferrer" target="_blank">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-primary-600/10 dark:bg-primary-400/10">
                <svg class="h-6 w-6 text-primary-600 dark:text-primary-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-medium dark:text-primary-200 text-primary-950 group-hover:underline">GitHub Issues</h3>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60">提交 Bug 报告或功能建议</p>
              </div>
            </div>
            <p class="text-sm dark:text-primary-200/70 text-primary-950/70">
              在 GitHub 上提交 Issue，我们会尽快回复。这是最直接的反馈方式。
            </p>
            <div class="flex items-center gap-1.5 text-sm text-primary-600 dark:text-primary-400 mt-auto">
              <span>前往 GitHub</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </a>
          
          <!-- GitHub Discussions -->
          <a class="flex flex-col gap-4 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl hover:border-primary-600/30 dark:hover:border-primary-400/30 transition-colors group" href="https://github.com/shuo-us/shuo/discussions" rel="noopener noreferrer" target="_blank">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-blue-500/10 dark:bg-blue-400/10">
                <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-medium dark:text-primary-200 text-primary-950 group-hover:underline">GitHub Discussions</h3>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60">参与社区讨论</p>
              </div>
            </div>
            <p class="text-sm dark:text-primary-200/70 text-primary-950/70">
              在 Discussions 中提问、分享想法、交流使用心得。这里是社区交流的地方。
            </p>
            <div class="flex items-center gap-1.5 text-sm text-primary-600 dark:text-primary-400 mt-auto">
              <span>参与讨论</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </a>
          
          <!-- Email -->
          <a class="flex flex-col gap-4 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl hover:border-primary-600/30 dark:hover:border-primary-400/30 transition-colors group" href="mailto:support@tanwei.co">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-green-500/10 dark:bg-green-400/10">
                <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M3 3H21C21.5523 3 22 3.44772 22 4V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V4C2 3.44772 2.44772 3 3 3ZM20 7.23792L12.0718 14.338L4 7.21594V19H20V7.23792ZM4.51146 5L12.0619 11.662L19.501 5H4.51146Z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-medium dark:text-primary-200 text-primary-950 group-hover:underline">邮件联系</h3>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60">support@tanwei.co</p>
              </div>
            </div>
            <p class="text-sm dark:text-primary-200/70 text-primary-950/70">
              对于商务合作或其他问题，欢迎通过邮件联系我们。
            </p>
            <div class="flex items-center gap-1.5 text-sm text-primary-600 dark:text-primary-400 mt-auto">
              <span>发送邮件</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </a>
          
          <!-- WeChat -->
          <button class="flex flex-col gap-4 p-6 bg-white border border-primary-900/10 dark:bg-primary-950 dark:border-primary-200/10 rounded-2xl hover:border-primary-600/30 dark:hover:border-primary-400/30 transition-colors group text-left cursor-pointer" type="button" aria-controls="wechat-service-qr-modal" aria-haspopup="dialog" data-modal-target="wechat-service-qr-modal">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-green-500/10 dark:bg-green-400/10">
                <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.11.24-.245 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-7.062-6.122zm-2.18 2.768c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-medium dark:text-primary-200 text-primary-950 group-hover:underline">微信公众号</h3>
                <p class="text-sm text-primary-950/60 dark:text-primary-200/60">扫码关注获取最新动态</p>
              </div>
            </div>
            <p class="text-sm dark:text-primary-200/70 text-primary-950/70">
              关注说说输入法微信公众号，获取最新更新和动态。
            </p>
            <div class="flex items-center gap-1.5 text-sm text-primary-600 dark:text-primary-400 mt-auto">
              <span>查看二维码</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </div>
          </button>
        </div>
        
        <!-- Additional Info -->
        <div class="mt-16 text-center">
          <div class="inline-flex items-center gap-2 px-6 py-3 bg-primary-500/5 dark:bg-primary-400/5 rounded-full">
            <svg class="h-5 w-5 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="text-sm dark:text-primary-200/70 text-primary-950/70">我们通常在 24-48 小时内回复</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
