                  </div>
                  <div class="items-center inline-flex gap-1.5 text-xs border font-medium px-3 py-1.5 rounded-lg bg-green-500/10 border-green-200/20 dark:text-green-400 text-green-700" data-astro-cid-ludp2yfi>
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" data-astro-cid-ludp2yfi>
                      <path d="M4.5 12.75l6 6 9-13.5" stroke-linecap="round" stroke-linejoin="round" data-astro-cid-ludp2yfi></path>
                    </svg>
                    口语过滤
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Section 2: Local First -->
        <div class="items-center gap-8 grid lg:gap-16 lg:grid-cols-2 scroll-mt-24" data-astro-cid-ludp2yfi id="local-first">
          <div class="items-center flex justify-center dark:hover:bg-primary-400/10 hover:bg-primary-500/10 bg-primary-500/5 dark:bg-primary-400/5 group min-h-[300px] p-6 rounded-2xl sm:p-8 transition-colors lg:order-1 order-2" data-astro-cid-ludp2yfi>
