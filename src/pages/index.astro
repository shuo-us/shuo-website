              </svg>
              下载使用
            </a>
            <a class="items-center justify-center rounded-full font-semibold gap-2 border focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 inline-flex px-8 sm:w-auto text-base w-full active:scale-95 hover:scale-105 py-4 transition-all border-primary-200 dark:border-primary-700 text-primary-950 dark:text-primary-200 hover:bg-primary-50 dark:hover:bg-primary-900/50" href="https://github.com/shuo-us/shuo" data-astro-cid-ewxirvlt>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" data-astro-cid-ewxirvlt>
                <path d="M12 1L21 5V11C21 16.55 17.16 21.74 12 23C6.84 21.74 3 16.55 3 11V5L12 1ZM12 3.18L5 6.3V11.22C5 15.54 7.84 19.85 12 20.97C16.16 19.85 19 15.54 19 11.22V6.3L12 3.18Z"></path>
