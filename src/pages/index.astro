---
import Layout from '../layouts/Layout.astro';
---

<Layout title="说说输入法，开源本地语音输入法">
  <section class="relative overflow-hidden pb-14 pt-20 sm:pb-24 sm:pt-24" data-astro-cid-ewxirvlt>
    <!-- Background blur decoration -->
    <div class="overflow-hidden -top-40 -z-10 absolute blur-3xl inset-x-0 sm:-top-80 transform-gpu" data-astro-cid-ewxirvlt aria-hidden="true">
      <div class="relative -translate-x-1/2 aspect-[1155/678] bg-gradient-to-tr dark:from-primary-800 dark:to-primary-900 from-primary-200 left-[calc(50%-11rem)] opacity-20 rotate-[30deg] sm:left-[calc(50%-30rem)] sm:w-[72.1875rem] to-primary-100 w-[36.125rem]" data-astro-cid-ewxirvlt style="clip-path:polygon(74.1% 44.1%,100% 61.6%,97.5% 26.9%,85.5% 0.1%,80.7% 2%,72.5% 32.5%,60.2% 62.4%,52.4% 68.1%,47.5% 58.3%,45.2% 34.5%,27.5% 76.7%,0.1% 64.9%,17.9% 100%,27.6% 76.8%,76.1% 97.7%,74.1% 44.1%)">
      </div>
    </div>
    
    <div class="max-w-2xl lg:max-w-7xl lg:px-8 mx-auto px-4 sm:px-6" data-astro-cid-ewxirvlt>
      <div class="flex flex-col gap-10 sm:gap-12" data-astro-cid-ewxirvlt>
        <div class="items-center flex flex-col gap-8 sm:gap-10" data-astro-cid-ewxirvlt>
          <div class="items-center flex flex-col gap-4 text-center max-w-4xl px-4 sm:gap-6" data-astro-cid-ewxirvlt>
            <span class="items-center inline-flex border gap-2 rounded-full dark:bg-primary-400/10 px-4 bg-primary-600/5 border-primary-600/10 dark:border-primary-400/10 dark:text-primary-400 font-medium py-1.5 text-primary-600 text-sm" data-astro-cid-ewxirvlt>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-astro-cid-ewxirvlt>
                <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" stroke-linecap="round" stroke-linejoin="round" data-astro-cid-ewxirvlt></path>
              </svg>
              本地优先
            </span>
            <h1 class="bg-clip-text bg-gradient-to-br dark:from-white dark:to-primary-400 dark:via-primary-200 font-semibold from-primary-950 lg:text-7xl md:text-6xl pb-1 sm:text-5xl text-4xl text-transparent to-primary-950 tracking-tight via-primary-700" data-astro-cid-ewxirvlt>
              开口说话，自然输入
            </h1>
            <p class="leading-relaxed dark:text-primary-200/70 text-primary-950/70 max-w-2xl md:text-2xl sm:text-xl text-lg" data-astro-cid-ewxirvlt>
              开源、本地优先的语音输入法，不绑定供应商，隐私由你掌控
            </p>
          </div>
          
          <!-- Download Section -->
          <div class="items-center flex flex-col gap-4 pt-2 sm:flex-row sm:w-auto w-full" data-astro-cid-ewxirvlt id="download-buttons">
            <a class="items-center justify-center rounded-full font-semibold gap-2 border focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 inline-flex px-8 sm:w-auto text-base w-full active:scale-95 hover:scale-105 py-4 transition-all bg-primary-900 dark:bg-primary-100 hover:bg-primary-800 dark:hover:bg-white border-transparent text-white dark:text-primary-950 shadow-lg hover:shadow-xl" href="https://github.com/shuo-us/shuo/releases/latest" data-astro-cid-ewxirvlt>
