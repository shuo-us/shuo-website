            </a>
          </div>
        </div>
        
        <!-- Interactive Steps Grid -->
        <div class="w-full border backdrop-blur-sm bg-white/50 border-primary-900/10 dark:bg-primary-950/50 dark:border-primary-200/10 overflow-hidden relative rounded-3xl shadow-primary-900/5 shadow-xl" data-astro-cid-ewxirvlt>
          <div class="grid grid-cols-1 dark:divide-primary-200/10 divide-primary-900/5 divide-y gap-0 md:divide-x md:divide-y-0 md:grid-cols-3" data-astro-cid-ewxirvlt>
            <!-- Step 1 -->
            <div class="items-center flex flex-col gap-4 cursor-default dark:hover:bg-primary-900/60 group hover:bg-white/60 md:p-12 p-8 transition-colors relative" data-astro-cid-ewxirvlt>
