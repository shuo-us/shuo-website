                  <div class="items-center inline-flex gap-1.5 text-xs border font-medium px-3 py-1.5 rounded-lg bg-indigo-500/10 border-indigo-200/20 dark:text-indigo-400 text-indigo-700" data-astro-cid-ludp2yfi>
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" data-astro-cid-ludp2yfi>
