              </div>
              <div class="text-center" data-astro-cid-ewxirvlt>
                <h3 class="dark:text-primary-200 text-primary-950 font-semibold mb-2 text-lg" data-astro-cid-ewxirvlt>自动输出</h3>
                <p class="text-sm dark:text-primary-200/60 text-primary-950/60" data-astro-cid-ewxirvlt>识别结果自动填入，支持口语过滤</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section class="pb-24 pt-4 sm:pb-24 sm:pt-8" data-astro-cid-ludp2yfi>
    <div class="max-w-2xl lg:max-w-7xl lg:px-8 mx-auto px-4 sm:px-6" data-astro-cid-ludp2yfi>
      <div class="flex flex-col gap-16 lg:gap-24" data-astro-cid-ludp2yfi>
        
        <!-- Section 1: Voice Input -->
        <div class="items-center gap-8 grid lg:gap-16 lg:grid-cols-2 scroll-mt-24" data-astro-cid-ludp2yfi id="voice-input">
          <div class="flex flex-col gap-6" data-astro-cid-ludp2yfi>
