              <div class="text-center space-y-2" data-astro-cid-ludp2yfi>
                <div class="dark:text-primary-400 text-primary-600 font-bold text-6xl" data-astro-cid-ludp2yfi>4x</div>
                <div class="font-medium dark:text-primary-200/70 text-primary-950/70 text-xl" data-astro-cid-ludp2yfi>比键盘打字快 4 倍</div>
              </div>
              <div class="space-y-4" data-astro-cid-ludp2yfi>
                <div class="items-center flex justify-center gap-4" data-astro-cid-ludp2yfi>
                  <div class="items-center flex flex-col bg-white border border-primary-900/5 dark:bg-primary-900 dark:border-primary-200/5 gap-2 px-5 py-3 rounded-xl shadow-sm" data-astro-cid-ludp2yfi>
