                <div class="duration-500 transition-transform absolute bg-primary-600/5 dark:bg-primary-400/10 group-hover:scale-110 inset-0 rounded-2xl" data-astro-cid-ewxirvlt></div>
                <div class="items-center flex justify-center absolute inset-0" data-astro-cid-ewxirvlt>
                  <svg class="dark:text-primary-400 text-primary-600 h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" data-astro-cid-ewxirvlt>
